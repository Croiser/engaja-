# ---------- Servidor ----------
NODE_ENV=development
PORT=3333

# ---------- Banco (PostgreSQL) ----------
# Container dedicado do projeto (docker-compose.yml), porta host 3398.
# DATABASE_URL = superusuário, usado só por migrations/seed (knexfile). IGNORA RLS.
DATABASE_URL=postgres://clube:clube@localhost:3398/clube_boa_forma
# APP_DATABASE_URL = role da API (clube_app, NOSUPERUSER) — SUJEITO ao RLS. É esta que a API usa.
APP_DATABASE_URL=postgres://clube_app:clube_app@localhost:3398/clube_boa_forma
# Fuso do negócio (Foz do Iguaçu). A conexão fixa isso p/ o dia do check-in.
DB_TIMEZONE=America/Sao_Paulo

# ---------- Auth (JWT) ----------
# Sessão. "manter conectado" usa a validade longa; senão, a curta.
JWT_SECRET=troque-por-um-segredo-forte-de-64-chars
JWT_EXPIRES=1d
JWT_EXPIRES_LONGO=30d

# Secret SEPARADO só para o QR da carteirinha (TTL curto). Nunca reusar o de sessão.
QR_SECRET=troque-por-outro-segredo-forte
QR_TTL_SEGUNDOS=90

# TTL do código de benefício do parceiro (segundos)
BENEFICIO_TTL_SEGUNDOS=600

# ---------- CORS ----------
# Domínio do front (PWA). Em produção: https://boaformafoz...
CORS_ORIGIN=http://localhost:5173

# ---------- Proxy / Rate-limit ----------
# Nº de proxies confiáveis à frente da API. 0 em dev (acesso direto).
# Em produção atrás do Cloudflare: 1. Cloudflare + nginx: 2. Errar isto quebra o rate-limit.
TRUST_PROXY=0

# ---------- Web Push (VAPID) ----------
# Gerar com: node -e "console.log(require('web-push').generateVAPIDKeys())"
# Sem estas chaves, o push é desligado (mural interno continua funcionando).
VAPID_PUBLIC=
VAPID_PRIVATE=
VAPID_SUBJECT=mailto:contato@seudominio.com.br
