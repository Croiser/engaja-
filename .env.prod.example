# Copiar para .env.prod e preencher antes de subir docker-compose.prod.yml.
# NUNCA commitar o .env.prod real (já está no .gitignore junto com .env).

NODE_ENV=production
PORT=3333

# Senha do superusuário Postgres (container db do compose de produção).
POSTGRES_PASSWORD=

# DATABASE_URL = superusuário, só para migrations/seed (rodar de dentro do container api
# ou de uma máquina com acesso à rede docker). Host "db" = nome do serviço no compose.
DATABASE_URL=postgres://clube:TROCAR_PELA_MESMA_SENHA_ACIMA@db:5432/clube_boa_forma
# APP_DATABASE_URL = role clube_app (NOSUPERUSER, sujeito a RLS) — é o que a API usa em runtime.
# A migration 0003_app_role.js cria essa role/senha — ver o valor gerado lá ou fixar via seed manual.
APP_DATABASE_URL=postgres://clube_app:clube_app@db:5432/clube_boa_forma
DB_TIMEZONE=America/Sao_Paulo

# JWT_SECRET / QR_SECRET: gerar segredos fortes e ÚNICOS de produção, nunca reusar os de dev.
# node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=
JWT_EXPIRES=1d
JWT_EXPIRES_LONGO=30d
QR_SECRET=
QR_TTL_SEGUNDOS=90

BENEFICIO_TTL_SEGUNDOS=600

# Domínio real do frontend em produção (sem barra final).
CORS_ORIGIN=https://app.SEUDOMINIO.com.br

# Atrás de nginx (reverse proxy) no mesmo host: 1. Se tiver Cloudflare na frente do nginx: 2.
TRUST_PROXY=1

# Web Push (VAPID) — gerar com: node -e "console.log(require('web-push').generateVAPIDKeys())"
VAPID_PUBLIC=
VAPID_PRIVATE=
VAPID_SUBJECT=mailto:contato@SEUDOMINIO.com.br
